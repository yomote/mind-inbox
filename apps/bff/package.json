{
  "name": "mind-inbox-bff",
  "version": "0.1.0",
  "private": true,
  "description": "BFF for mind-inbox — Azure Functions v4 + tRPC",
  "main": "dist/src/functions/*.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start": "npm run build && func start",
    "dev": "concurrently \"npm run build:watch\" \"func start --port 7071\"",
    "lint": "eslint src",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@azure/functions": "^4.5.0",
    "@trpc/server": "^11.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^10.3.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.59.1",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=22"
  }
}
